
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="styles/main.css">
    <title>Blog Website Project</title>
</head>
<body>
    <div class="post-background pt-4 pb-5">
        <div class="container py-5">
            <div class="row g-3 heroe-background">
                <div class="col-md-12 col-lg-12">
                    <h4 class="mb-3 display-5 fw-bold trirong-semibold">
                        <font dir="auto" style="vertical-align: inherit">
                            <font dir="auto" style="vertical-align: inherit">Edit your Blog Post!</font>
                        </font>
                    </h4>
                    <form action="/update" method="POST" class="needs-validation">
                        <input type="hidden" name="id" value="<%= blogPost.id %>">

                        <div class="row g-3">
                            <div class="col-sm-6">
                                <label for="fName" class="form-label rasa-p lead">
                                    <font dir="auto" style="vertical-align: inherit">
                                        <font dir="auto" style="vertical-align: inherit">First name</font>
                                    </font>
                                </label>
                                <input
                                    type="text"
                                    class="form-control"
                                    id="firstName"
                                    name="fName"
                                    placeholder=""
                                    value="<%= blogPost.firstName %>"
                                    required=""
                                />
                            </div>

                            <div class="col-sm-6">
                                <label for="lName" class="form-label rasa-p lead">
                                    <font dir="auto" style="vertical-align: inherit">
                                        <font dir="auto" style="vertical-align: inherit">Last name</font>
                                    </font>
                                </label>
                                <input
                                    type="text"
                                    class="form-control"
                                    id="lastName"
                                    name="lName"
                                    placeholder=""
                                    value="<%= blogPost.lastName %>"
                                    required=""
                                />
                            </div>

                            <div class="col-12">
                                <label for="title" class="form-label rasa-p lead">
                                    <font dir="auto" style="vertical-align: inherit">
                                        <font dir="auto" style="vertical-align: inherit">Blog Title</font>
                                    </font>
                                </label>
                                <input
                                    type="text"
                                    class="form-control"
                                    id="title"
                                    name="title"
                                    placeholder=""
                                    value="<%= blogPost.blogTitle %>"
                                    required=""
                                />
                            </div>

                            <div class="col-12">
                                <label for="content" class="form-label rasa-p lead">
                                    <font dir="auto" style="vertical-align: inherit">
                                        <font dir="auto" style="vertical-align: inherit">Blog Content</font>
                                    </font>
                                </label>
                                <textarea class="form-control" id="content" name="content" style="height:120px; resize: none;" rows="3" required><%= blogPost.blogContent %></textarea><br><br>
                            </div>
                        </div>

                        <hr class="my-4"/>
                            
                        <button class="w-100 btn btn-primary btn-lg rasa-p" type="submit">
                            <font dir="auto" style="vertical-align: inherit">
                                <font dir="auto" style="vertical-align: inherit">Update</font>
                            </font>
                        </button>

                    </form>
                </div>
            </div>
        </div>
    </div>
</body>